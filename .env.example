# Circle API Configuration
VITE_CIRCLE_API_KEY=your_circle_api_key_here

# Arc Testnet RPC
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# App Configuration
VITE_APP_NAME=Zilarc
VITE_APP_BASE_URL=https://zilarc.vercel.app

# --- Foundry / forge deploy (kept out of Vite bundle) ---
# Your EOA private key (DO NOT COMMIT). Used by forge script AND by the
# /api/swap server route when proxying App Kit swap() through Viem.
PRIVATE_KEY=0xyour_private_key_here

# Arc Testnet RPC (also surfaced as VITE_ARC_RPC_URL above; this one is for forge/cast)
ARCTEST_RPC_URL=https://rpc.testnet.arc.network

# --- Zilarc Router (deployed via DeployRouter.s.sol) ---
# Single-call AMM router that fronts all 6 ZilarcSwap pools on Arc Testnet.
# Without this, the swap UI falls back to direct pool calls (still works, but
# slippage is best-effort instead of enforced on-chain).
VITE_ZILARC_ROUTER=0x72F8C8e1b027aca6d4e2474E58fc4FdFB1D193b9

# --- Circle App Kit (server-side only) ---
# Required for App Kit swap() to work. Get one at:
#   1. https://console.circle.com  -> Keys -> + Create key -> Kit Key
# Kit keys are network-agnostic (work on testnet + mainnet).
# NEVER expose this to the browser bundle. The /api/swap route reads
# it server-side only.
KIT_KEY=your_kit_key_here